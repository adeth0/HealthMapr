# HealthMapr Environment Variables
# Copy this file to .env.local and fill in your values

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: supabase.com → Your Project → Connect → React/Vite
VITE_SUPABASE_URL=https://aonyvtbsvyrnkwsabmug.supabase.co
