# ── Strava ────────────────────────────────────────────────────────────────────
# Get from: strava.com/settings/api → Create App
# Client ID is public (safe in frontend). Secret goes server-side only.
# VITE_STRAVA_CLIENT_ID=12345
# supabase secrets set STRAVA_CLIENT_ID=12345
# supabase secrets set STRAVA_CLIENT_SECRET=abc123...

# ── Anthropic (set as Supabase secret, NOT here) ──────────────────────────────
# supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# Never put this in .env.local — it goes server-side only
